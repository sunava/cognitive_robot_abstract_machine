<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="modern_kitchen_from_image">

  <xacro:property name="PI" value="3.1415926535897931"/>

  <material name="white">
    <color rgba="0.96 0.96 0.96 1.0"/>
  </material>
  <material name="light_wood">
    <color rgba="0.73 0.56 0.38 1.0"/>
  </material>
  <material name="dark_metal">
    <color rgba="0.18 0.18 0.18 1.0"/>
  </material>
  <material name="steel">
    <color rgba="0.72 0.72 0.74 1.0"/>
  </material>
  <material name="glass_tint">
    <color rgba="0.75 0.9 1.0 0.25"/>
  </material>
  <material name="counter_top">
    <color rgba="0.97 0.97 0.97 1.0"/>
  </material>
  <material name="floor_wood">
    <color rgba="0.84 0.76 0.67 1.0"/>
  </material>
  <material name="warm_tile">
    <color rgba="0.92 0.87 0.78 1.0"/>
  </material>

  <link name="world"/>

  <joint name="world_to_room" type="fixed">
    <parent link="world"/>
    <child link="room"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="room"/>

  <xacro:macro name="box_link" params="name parent xyz rpy size mass material">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${size}"/>
        </geometry>
        <material name="${material}"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${size}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
      </inertial>
    </link>
    <joint name="${parent}_to_${name}" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="cylinder_link" params="name parent xyz rpy radius length mass material">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="${material}"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${mass}"/>
        <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="0.2" iyz="0.0" izz="0.2"/>
      </inertial>
    </link>
    <joint name="${parent}_to_${name}" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="chair" params="name parent xyz yaw">
    <xacro:box_link name="${name}_seat" parent="${parent}" xyz="${xyz}" rpy="0 0 ${yaw}" size="0.48 0.46 0.06" mass="6.0" material="light_wood"/>
    <xacro:box_link name="${name}_cushion" parent="${name}_seat" xyz="0 0 0.05" rpy="0 0 0" size="0.46 0.44 0.08" mass="1.0" material="white"/>
    <xacro:box_link name="${name}_back" parent="${name}_seat" xyz="-0.18 0 0.27" rpy="0 0 0" size="0.05 0.42 0.42" mass="2.0" material="light_wood"/>
    <xacro:box_link name="${name}_leg_fl" parent="${name}_seat" xyz="0.18 0.17 -0.34" rpy="0 0 0" size="0.05 0.05 0.68" mass="1.0" material="dark_metal"/>
    <xacro:box_link name="${name}_leg_fr" parent="${name}_seat" xyz="0.18 -0.17 -0.34" rpy="0 0 0" size="0.05 0.05 0.68" mass="1.0" material="dark_metal"/>
    <xacro:box_link name="${name}_leg_rl" parent="${name}_seat" xyz="-0.18 0.17 -0.34" rpy="0 0 0" size="0.05 0.05 0.68" mass="1.0" material="dark_metal"/>
    <xacro:box_link name="${name}_leg_rr" parent="${name}_seat" xyz="-0.18 -0.17 -0.34" rpy="0 0 0" size="0.05 0.05 0.68" mass="1.0" material="dark_metal"/>
  </xacro:macro>

  <xacro:macro name="pendant" params="name parent xyz">
    <xacro:cylinder_link name="${name}_chain" parent="${parent}" xyz="${xyz}" rpy="0 0 0" radius="0.01" length="0.9" mass="0.2" material="dark_metal"/>
    <xacro:cylinder_link name="${name}_shade" parent="${name}_chain" xyz="0 0 -0.48" rpy="${PI/2} 0 0" radius="0.20" length="0.28" mass="0.8" material="dark_metal"/>
  </xacro:macro>

  <xacro:box_link name="floor" parent="room" xyz="2.4 2.0 -0.02" rpy="0 0 0" size="4.8 4.0 0.04" mass="1000.0" material="floor_wood"/>

  <xacro:box_link name="back_wall" parent="room" xyz="2.4 0 1.4" rpy="0 0 0" size="4.8 0.12 2.8" mass="1000.0" material="white"/>
  <xacro:box_link name="left_wall" parent="room" xyz="0 2.0 1.4" rpy="0 0 0" size="0.12 4.0 2.8" mass="1000.0" material="white"/>
  <xacro:box_link name="right_wall_a" parent="room" xyz="4.8 0.7 1.4" rpy="0 0 0" size="0.12 1.4 2.8" mass="1000.0" material="white"/>
  <xacro:box_link name="right_wall_b" parent="room" xyz="4.8 3.35 1.4" rpy="0 0 0" size="0.12 1.3 2.8" mass="1000.0" material="white"/>
  <xacro:box_link name="ceiling" parent="room" xyz="2.4 2.0 2.78" rpy="0 0 0" size="4.8 4.0 0.04" mass="500.0" material="white"/>

  <xacro:box_link name="counter_left_base" parent="room" xyz="0.85 1.65 0.44" rpy="0 0 0" size="1.70 0.62 0.88" mass="120.0" material="light_wood"/>
  <xacro:box_link name="counter_back_base" parent="room" xyz="2.25 0.31 0.44" rpy="0 0 0" size="2.50 0.62 0.88" mass="160.0" material="light_wood"/>
  <xacro:box_link name="counter_left_top" parent="room" xyz="0.85 1.65 0.91" rpy="0 0 0" size="1.78 0.68 0.06" mass="40.0" material="counter_top"/>
  <xacro:box_link name="counter_back_top" parent="room" xyz="2.25 0.31 0.91" rpy="0 0 0" size="2.58 0.68 0.06" mass="55.0" material="counter_top"/>

  <xacro:box_link name="backsplash_left" parent="room" xyz="0.85 1.33 1.12" rpy="0 0 0" size="1.78 0.03 0.42" mass="10.0" material="warm_tile"/>
  <xacro:box_link name="backsplash_back" parent="room" xyz="2.25 0.63 1.12" rpy="0 0 0" size="2.58 0.03 0.42" mass="10.0" material="warm_tile"/>

  <xacro:box_link name="island_base" parent="room" xyz="3.15 2.45 0.44" rpy="0 0 0" size="1.85 0.95 0.88" mass="180.0" material="light_wood"/>
  <xacro:box_link name="island_top" parent="room" xyz="3.15 2.45 0.94" rpy="0 0 0" size="1.95 1.05 0.08" mass="80.0" material="counter_top"/>
  <xacro:box_link name="island_waterfall_left" parent="room" xyz="2.22 2.45 0.46" rpy="0 0 0" size="0.05 1.05 0.92" mass="40.0" material="counter_top"/>

  <xacro:box_link name="fridge" parent="room" xyz="3.65 0.35 1.05" rpy="0 0 0" size="0.90 0.78 2.10" mass="150.0" material="steel"/>

  <xacro:box_link name="window_1" parent="room" xyz="1.95 0.065 1.45" rpy="0 0 0" size="0.36 0.03 1.00" mass="5.0" material="glass_tint"/>
  <xacro:box_link name="window_2" parent="room" xyz="2.40 0.065 1.45" rpy="0 0 0" size="0.36 0.03 1.00" mass="5.0" material="glass_tint"/>
  <xacro:box_link name="window_3" parent="room" xyz="2.85 0.065 1.45" rpy="0 0 0" size="0.36 0.03 1.00" mass="5.0" material="glass_tint"/>

  <xacro:box_link name="sliding_door_glass" parent="room" xyz="4.74 2.45 1.25" rpy="0 0 0" size="0.03 1.75 2.40" mass="30.0" material="glass_tint"/>

  <xacro:box_link name="sink" parent="room" xyz="2.40 0.33 0.84" rpy="0 0 0" size="0.55 0.42 0.16" mass="8.0" material="steel"/>
  <xacro:cylinder_link name="faucet" parent="room" xyz="2.40 0.16 1.05" rpy="0 0 0" radius="0.02" length="0.32" mass="0.5" material="dark_metal"/>

  <xacro:box_link name="cooktop" parent="room" xyz="0.40 1.63 0.94" rpy="0 0 0" size="0.75 0.50 0.04" mass="12.0" material="dark_metal"/>
  <xacro:box_link name="oven" parent="room" xyz="0.40 1.63 0.47" rpy="0 0 0" size="0.78 0.60 0.88" mass="80.0" material="dark_metal"/>
  <xacro:box_link name="range_hood" parent="room" xyz="0.40 1.33 1.72" rpy="0 0 0" size="0.95 0.50 0.10" mass="18.0" material="steel"/>

  <xacro:box_link name="upper_cabinet_left" parent="room" xyz="0.88 1.32 1.92" rpy="0 0 0" size="1.55 0.38 1.10" mass="80.0" material="white"/>
  <xacro:box_link name="upper_cabinet_right" parent="room" xyz="3.98 0.34 1.88" rpy="0 0 0" size="1.05 0.38 0.85" mass="60.0" material="white"/>
  <xacro:box_link name="tall_cabinet_right" parent="room" xyz="4.25 0.34 1.28" rpy="0 0 0" size="0.60 0.68 2.56" mass="100.0" material="white"/>

  <xacro:chair name="chair_1" parent="room" xyz="2.55 3.10 0.52" yaw="0"/>
  <xacro:chair name="chair_2" parent="room" xyz="3.00 3.10 0.52" yaw="0"/>
  <xacro:chair name="chair_3" parent="room" xyz="3.45 3.10 0.52" yaw="0"/>
  <xacro:chair name="chair_4" parent="room" xyz="3.90 3.10 0.52" yaw="0"/>

  <xacro:pendant name="pendant_1" parent="room" xyz="2.60 2.45 2.30"/>
  <xacro:pendant name="pendant_2" parent="room" xyz="3.25 2.45 2.30"/>
  <xacro:pendant name="pendant_3" parent="room" xyz="3.90 2.45 2.30"/>

  <xacro:box_link name="plate_1" parent="island_top" xyz="-0.45 0.18 0.06" rpy="0 0 0" size="0.22 0.22 0.02" mass="0.2" material="white"/>
  <xacro:box_link name="plate_2" parent="island_top" xyz="0.0 0.18 0.06" rpy="0 0 0" size="0.22 0.22 0.02" mass="0.2" material="white"/>
  <xacro:box_link name="plate_3" parent="island_top" xyz="0.45 0.18 0.06" rpy="0 0 0" size="0.22 0.22 0.02" mass="0.2" material="white"/>
  <xacro:box_link name="plant" parent="counter_back_top" xyz="-0.58 0.0 0.10" rpy="0 0 0" size="0.12 0.12 0.20" mass="0.3" material="light_wood"/>

  <!-- Swap these simple boxes with real COB assets if present in your workspace.
       The historic COB environment packages contain ipa-kitchen URDF worlds and
       separate object spawning support, rather than this exact modern kitchen layout. -->

</robot>
