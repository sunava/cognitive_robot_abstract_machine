<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="modern_kitchen_from_image">
  <xacro:property name="pi" value="3.1415926535897931"/>

  <material name="white">
    <color rgba="0.96 0.96 0.96 1.0"/>
  </material>
  <material name="oak">
    <color rgba="0.70 0.54 0.36 1.0"/>
  </material>
  <material name="quartz">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <material name="steel">
    <color rgba="0.70 0.72 0.74 1.0"/>
  </material>
  <material name="glass_tint">
    <color rgba="0.75 0.88 0.95 0.35"/>
  </material>
  <material name="floor_wood">
    <color rgba="0.82 0.74 0.63 1.0"/>
  </material>

  <link name="world"/>

  <xacro:macro name="fixed_box" params="name parent x y z sx sy sz mat">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
        <material name="${mat}"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="fixed_cylinder" params="name parent x y z radius length r p yaw mat">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${r} ${p} ${yaw}"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="${mat}"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${r} ${p} ${yaw}"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="bar_chair" params="name parent x y z yaw">
    <link name="${name}_seat">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.46 0.42 0.08"/>
        </geometry>
        <material name="quartz"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.46 0.42 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="3.0"/>
        <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.05"/>
      </inertial>
    </link>
    <joint name="${name}_seat_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}_seat"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 ${yaw}"/>
    </joint>

    <xacro:fixed_box name="${name}_back" parent="${name}_seat" x="0.0" y="-0.17" z="0.21" sx="0.40" sy="0.05" sz="0.34" mat="quartz"/>

    <xacro:fixed_cylinder name="${name}_leg_fl" parent="${name}_seat" x="0.17" y="0.14" z="-0.34" radius="0.03" length="0.68" r="0" p="0" yaw="0" mat="oak"/>
    <xacro:fixed_cylinder name="${name}_leg_fr" parent="${name}_seat" x="0.17" y="-0.14" z="-0.34" radius="0.03" length="0.68" r="0" p="0" yaw="0" mat="oak"/>
    <xacro:fixed_cylinder name="${name}_leg_rl" parent="${name}_seat" x="-0.17" y="0.14" z="-0.34" radius="0.03" length="0.68" r="0" p="0" yaw="0" mat="oak"/>
    <xacro:fixed_cylinder name="${name}_leg_rr" parent="${name}_seat" x="-0.17" y="-0.14" z="-0.34" radius="0.03" length="0.68" r="0" p="0" yaw="0" mat="oak"/>

    <xacro:fixed_box name="${name}_footrest_front" parent="${name}_seat" x="0.0" y="0.14" z="-0.52" sx="0.32" sy="0.03" sz="0.03" mat="oak"/>
    <xacro:fixed_box name="${name}_footrest_back" parent="${name}_seat" x="0.0" y="-0.14" z="-0.52" sx="0.32" sy="0.03" sz="0.03" mat="oak"/>
    <xacro:fixed_box name="${name}_footrest_left" parent="${name}_seat" x="-0.17" y="0.0" z="-0.52" sx="0.03" sy="0.28" sz="0.03" mat="oak"/>
    <xacro:fixed_box name="${name}_footrest_right" parent="${name}_seat" x="0.17" y="0.0" z="-0.52" sx="0.03" sy="0.28" sz="0.03" mat="oak"/>
  </xacro:macro>

  <xacro:fixed_box name="floor" parent="world" x="0.0" y="0.0" z="-0.025" sx="7.0" sy="5.5" sz="0.05" mat="floor_wood"/>

  <xacro:fixed_box name="back_wall" parent="world" x="0.0" y="2.75" z="1.45" sx="7.0" sy="0.05" sz="2.90" mat="white"/>
  <xacro:fixed_box name="right_wall" parent="world" x="3.475" y="0.0" z="1.45" sx="0.05" sy="5.5" sz="2.90" mat="white"/>
  <xacro:fixed_box name="left_wall" parent="world" x="-3.475" y="0.0" z="1.45" sx="0.05" sy="5.5" sz="2.90" mat="white"/>

  <xacro:fixed_box name="counter_left_base" parent="world" x="-2.20" y="2.35" z="0.42" sx="2.20" sy="0.60" sz="0.84" mat="oak"/>
  <xacro:fixed_box name="counter_back_base" parent="world" x="-0.35" y="2.35" z="0.42" sx="2.90" sy="0.60" sz="0.84" mat="oak"/>
  <xacro:fixed_box name="counter_left_top" parent="world" x="-2.20" y="2.35" z="0.88" sx="2.24" sy="0.64" sz="0.04" mat="quartz"/>
  <xacro:fixed_box name="counter_back_top" parent="world" x="-0.35" y="2.35" z="0.88" sx="2.94" sy="0.64" sz="0.04" mat="quartz"/>

  <xacro:fixed_box name="upper_left_cabinet_1" parent="world" x="-2.55" y="2.42" z="2.08" sx="1.10" sy="0.38" sz="1.14" mat="white"/>
  <xacro:fixed_box name="upper_left_cabinet_2" parent="world" x="-1.35" y="2.42" z="2.08" sx="1.10" sy="0.38" sz="1.14" mat="white"/>
  <xacro:fixed_box name="upper_right_cabinet" parent="world" x="1.65" y="2.42" z="2.04" sx="1.20" sy="0.38" sz="1.06" mat="white"/>

  <xacro:fixed_box name="range_block" parent="world" x="-2.85" y="2.28" z="0.46" sx="0.90" sy="0.68" sz="0.92" mat="black"/>
  <xacro:fixed_box name="hood_block" parent="world" x="-3.00" y="2.18" z="1.95" sx="1.10" sy="0.55" sz="0.20" mat="steel"/>

  <xacro:fixed_box name="sink_block" parent="world" x="-0.15" y="2.36" z="0.84" sx="0.65" sy="0.46" sz="0.12" mat="steel"/>
  <xacro:fixed_cylinder name="faucet" parent="world" x="-0.15" y="2.23" z="1.03" radius="0.015" length="0.36" r="0" p="0" yaw="0" mat="black"/>

  <xacro:fixed_box name="window_left" parent="world" x="-0.95" y="2.72" z="1.60" sx="0.42" sy="0.03" sz="1.10" mat="glass_tint"/>
  <xacro:fixed_box name="window_mid" parent="world" x="-0.25" y="2.72" z="1.60" sx="0.42" sy="0.03" sz="1.10" mat="glass_tint"/>
  <xacro:fixed_box name="window_right" parent="world" x="0.45" y="2.72" z="1.60" sx="0.42" sy="0.03" sz="1.10" mat="glass_tint"/>

  <xacro:fixed_box name="fridge" parent="world" x="1.55" y="2.25" z="1.05" sx="0.95" sy="0.75" sz="2.10" mat="steel"/>
  <xacro:fixed_box name="open_shelf" parent="world" x="2.25" y="2.38" z="1.45" sx="0.36" sy="0.42" sz="1.70" mat="white"/>

  <xacro:fixed_box name="island_base" parent="world" x="1.00" y="0.70" z="0.43" sx="2.40" sy="0.95" sz="0.86" mat="oak"/>
  <xacro:fixed_box name="island_top" parent="world" x="1.00" y="0.70" z="0.90" sx="2.55" sy="1.10" sz="0.05" mat="quartz"/>
  <xacro:fixed_box name="island_waterfall_left" parent="world" x="-0.25" y="0.70" z="0.43" sx="0.05" sy="1.10" sz="0.86" mat="quartz"/>
  <xacro:fixed_box name="island_waterfall_right" parent="world" x="2.25" y="0.70" z="0.43" sx="0.05" sy="1.10" sz="0.86" mat="quartz"/>

  <xacro:fixed_cylinder name="pendant_1" parent="world" x="0.45" y="1.05" z="2.15" radius="0.16" length="0.34" r="0" p="0" yaw="0" mat="black"/>
  <xacro:fixed_cylinder name="pendant_2" parent="world" x="1.35" y="1.05" z="2.15" radius="0.16" length="0.34" r="0" p="0" yaw="0" mat="black"/>
  <xacro:fixed_cylinder name="pendant_3" parent="world" x="2.25" y="1.05" z="2.05" radius="0.14" length="0.30" r="0" p="0" yaw="0" mat="black"/>

  <xacro:bar_chair name="chair_1" parent="world" x="0.10" y="-0.10" z="0.66" yaw="0"/>
  <xacro:bar_chair name="chair_2" parent="world" x="0.85" y="-0.10" z="0.66" yaw="0"/>
  <xacro:bar_chair name="chair_3" parent="world" x="1.60" y="-0.10" z="0.66" yaw="0"/>
  <xacro:bar_chair name="chair_4" parent="world" x="2.35" y="-0.10" z="0.66" yaw="0"/>
</robot>
