<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="classic_kitchen_from_image">
  <xacro:property name="pi" value="3.1415926535897931"/>

  <material name="wall_light">
    <color rgba="0.94 0.91 0.86 1.0"/>
  </material>
  <material name="cabinet_cream">
    <color rgba="0.86 0.81 0.74 1.0"/>
  </material>
  <material name="counter_dark">
    <color rgba="0.10 0.10 0.11 1.0"/>
  </material>
  <material name="metal">
    <color rgba="0.72 0.72 0.74 1.0"/>
  </material>
  <material name="gold">
    <color rgba="0.78 0.63 0.24 1.0"/>
  </material>
  <material name="glass_tint">
    <color rgba="0.85 0.90 0.95 0.30"/>
  </material>
  <material name="black_panel">
    <color rgba="0.06 0.06 0.07 1.0"/>
  </material>
  <material name="floor_dark">
    <color rgba="0.18 0.14 0.11 1.0"/>
  </material>
  <material name="chair_fabric">
    <color rgba="0.77 0.72 0.67 1.0"/>
  </material>
  <material name="chair_wood">
    <color rgba="0.20 0.12 0.08 1.0"/>
  </material>

  <link name="world"/>

  <xacro:macro name="fixed_box" params="name parent x y z sx sy sz mat">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
        <material name="${mat}"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="fixed_cylinder" params="name parent x y z radius length r p yaw mat">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${r} ${p} ${yaw}"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="${mat}"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${r} ${p} ${yaw}"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="dining_chair" params="name parent x y z yaw">
    <link name="${name}_seat">
      <visual>
        <geometry>
          <box size="0.48 0.48 0.08"/>
        </geometry>
        <material name="chair_fabric"/>
      </visual>
      <collision>
        <geometry>
          <box size="0.48 0.48 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/>
      </inertial>
    </link>
    <joint name="${name}_seat_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}_seat"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 ${yaw}"/>
    </joint>

    <xacro:fixed_box name="${name}_back" parent="${name}_seat" x="0.0" y="-0.20" z="0.32" sx="0.46" sy="0.06" sz="0.60" mat="chair_fabric"/>

    <xacro:fixed_cylinder name="${name}_leg_fl" parent="${name}_seat" x="0.18" y="0.18" z="-0.24" radius="0.025" length="0.48" r="0" p="0" yaw="0" mat="chair_wood"/>
    <xacro:fixed_cylinder name="${name}_leg_fr" parent="${name}_seat" x="0.18" y="-0.18" z="-0.24" radius="0.025" length="0.48" r="0" p="0" yaw="0" mat="chair_wood"/>
    <xacro:fixed_cylinder name="${name}_leg_rl" parent="${name}_seat" x="-0.18" y="0.18" z="-0.24" radius="0.025" length="0.48" r="0" p="0" yaw="0" mat="chair_wood"/>
    <xacro:fixed_cylinder name="${name}_leg_rr" parent="${name}_seat" x="-0.18" y="-0.18" z="-0.24" radius="0.025" length="0.48" r="0" p="0" yaw="0" mat="chair_wood"/>
  </xacro:macro>

  <!-- Floor -->
  <xacro:fixed_box name="floor" parent="world" x="0.0" y="0.0" z="-0.03" sx="7.0" sy="5.5" sz="0.06" mat="floor_dark"/>

  <!-- Walls -->
  <xacro:fixed_box name="back_wall" parent="world" x="0.0" y="2.75" z="1.6" sx="7.0" sy="0.05" sz="3.2" mat="wall_light"/>
  <xacro:fixed_box name="left_wall" parent="world" x="-3.475" y="0.0" z="1.6" sx="0.05" sy="5.5" sz="3.2" mat="wall_light"/>
  <xacro:fixed_box name="right_wall" parent="world" x="3.475" y="0.0" z="1.6" sx="0.05" sy="5.5" sz="3.2" mat="wall_light"/>

  <!-- Back lower run -->
  <xacro:fixed_box name="back_counter_left_base" parent="world" x="-1.90" y="2.35" z="0.42" sx="1.70" sy="0.62" sz="0.84" mat="cabinet_cream"/>
  <xacro:fixed_box name="back_counter_center_base" parent="world" x="0.10" y="2.35" z="0.42" sx="1.60" sy="0.62" sz="0.84" mat="cabinet_cream"/>
  <xacro:fixed_box name="back_counter_right_base" parent="world" x="1.85" y="2.35" z="0.42" sx="1.00" sy="0.62" sz="0.84" mat="cabinet_cream"/>

  <!-- Countertops -->
  <xacro:fixed_box name="back_counter_left_top" parent="world" x="-1.90" y="2.35" z="0.88" sx="1.74" sy="0.66" sz="0.05" mat="counter_dark"/>
  <xacro:fixed_box name="back_counter_center_top" parent="world" x="0.10" y="2.35" z="0.88" sx="1.64" sy="0.66" sz="0.05" mat="counter_dark"/>
  <xacro:fixed_box name="back_counter_right_top" parent="world" x="1.85" y="2.35" z="0.88" sx="1.04" sy="0.66" sz="0.05" mat="counter_dark"/>

  <!-- Left side return under windows -->
  <xacro:fixed_box name="left_return_base" parent="world" x="-2.70" y="1.45" z="0.42" sx="1.10" sy="1.20" sz="0.84" mat="cabinet_cream"/>
  <xacro:fixed_box name="left_return_top" parent="world" x="-2.70" y="1.45" z="0.88" sx="1.14" sy="1.24" sz="0.05" mat="counter_dark"/>

  <!-- Front peninsula / island -->
  <xacro:fixed_box name="peninsula_base" parent="world" x="1.15" y="0.95" z="0.42" sx="2.10" sy="0.90" sz="0.84" mat="cabinet_cream"/>
  <xacro:fixed_box name="peninsula_top" parent="world" x="1.15" y="0.95" z="0.88" sx="2.20" sy="1.00" sz="0.05" mat="counter_dark"/>

  <!-- Upper cabinets -->
  <xacro:fixed_box name="upper_left_cabinet" parent="world" x="-2.90" y="2.42" z="2.15" sx="1.10" sy="0.38" sz="1.50" mat="cabinet_cream"/>
  <xacro:fixed_box name="upper_mid_left_cabinet" parent="world" x="-0.75" y="2.42" z="2.10" sx="0.60" sy="0.38" sz="1.40" mat="cabinet_cream"/>
  <xacro:fixed_box name="upper_mid_right_cabinet" parent="world" x="-0.05" y="2.42" z="2.10" sx="0.60" sy="0.38" sz="1.40" mat="cabinet_cream"/>

  <!-- Tall pantry cabinets -->
  <xacro:fixed_box name="tall_left_pantry" parent="world" x="-0.80" y="2.28" z="1.45" sx="0.65" sy="0.72" sz="2.90" mat="cabinet_cream"/>
  <xacro:fixed_box name="tall_right_pantry" parent="world" x="-0.10" y="2.28" z="1.45" sx="0.65" sy="0.72" sz="2.90" mat="cabinet_cream"/>

  <!-- Windows -->
  <xacro:fixed_box name="window_left" parent="world" x="-2.15" y="2.72" z="1.75" sx="0.70" sy="0.03" sz="1.35" mat="glass_tint"/>
  <xacro:fixed_box name="window_right" parent="world" x="-1.35" y="2.72" z="1.75" sx="0.70" sy="0.03" sz="1.35" mat="glass_tint"/>

  <!-- Door -->
  <xacro:fixed_box name="door_panel" parent="world" x="2.85" y="2.71" z="1.10" sx="0.95" sy="0.04" sz="2.20" mat="white"/>
  <xacro:fixed_box name="door_window_1" parent="world" x="2.85" y="2.73" z="1.75" sx="0.28" sy="0.02" sz="0.60" mat="glass_tint"/>
  <xacro:fixed_box name="door_window_2" parent="world" x="3.10" y="2.73" z="1.75" sx="0.28" sy="0.02" sz="0.60" mat="glass_tint"/>

  <!-- Range and black backsplash -->
  <xacro:fixed_box name="range_block" parent="world" x="0.65" y="2.26" z="0.50" sx="0.95" sy="0.75" sz="1.00" mat="metal"/>
  <xacro:fixed_box name="black_backsplash" parent="world" x="0.65" y="2.60" z="1.55" sx="1.35" sy="0.05" sz="1.70" mat="black_panel"/>

  <!-- Hood -->
  <xacro:fixed_box name="hood_lower" parent="world" x="0.65" y="2.32" z="2.25" sx="1.60" sy="0.55" sz="0.22" mat="white"/>
  <xacro:fixed_box name="hood_body" parent="world" x="0.65" y="2.30" z="2.85" sx="1.05" sy="0.50" sz="1.00" mat="wall_light"/>

  <!-- Hanging rod and copper pans -->
  <xacro:fixed_box name="pan_rod" parent="world" x="0.65" y="2.55" z="1.88" sx="1.00" sy="0.03" sz="0.03" mat="gold"/>
  <xacro:fixed_cylinder name="pan_1" parent="world" x="0.10" y="2.48" z="1.70" radius="0.10" length="0.03" r="${pi/2}" p="0" yaw="0" mat="gold"/>
  <xacro:fixed_cylinder name="pan_2" parent="world" x="0.45" y="2.48" z="1.78" radius="0.07" length="0.025" r="${pi/2}" p="0" yaw="0" mat="gold"/>
  <xacro:fixed_cylinder name="pan_3" parent="world" x="0.78" y="2.48" z="1.76" radius="0.06" length="0.025" r="${pi/2}" p="0" yaw="0" mat="gold"/>
  <xacro:fixed_cylinder name="pan_4" parent="world" x="1.18" y="2.48" z="1.70" radius="0.11" length="0.03" r="${pi/2}" p="0" yaw="0" mat="gold"/>

  <!-- Sink and faucet -->
  <xacro:fixed_box name="sink_block" parent="world" x="-1.72" y="2.34" z="0.83" sx="0.72" sy="0.48" sz="0.14" mat="white"/>
  <xacro:fixed_cylinder name="faucet_base" parent="world" x="-1.92" y="2.18" z="1.03" radius="0.02" length="0.12" r="0" p="0" yaw="0" mat="gold"/>
  <xacro:fixed_cylinder name="faucet_neck" parent="world" x="-1.92" y="2.14" z="1.15" radius="0.015" length="0.36" r="0" p="${pi/2}" yaw="0" mat="gold"/>

  <!-- Dishwasher under sink side -->
  <xacro:fixed_box name="dishwasher" parent="world" x="-2.35" y="2.30" z="0.43" sx="0.70" sy="0.70" sz="0.86" mat="metal"/>

  <!-- Small wall sconce -->
  <xacro:fixed_cylinder name="sconce_mount" parent="world" x="-1.05" y="2.52" z="1.95" radius="0.07" length="0.03" r="${pi/2}" p="0" yaw="0" mat="gold"/>
  <xacro:fixed_cylinder name="sconce_shade" parent="world" x="-1.05" y="2.45" z="2.08" radius="0.08" length="0.14" r="0" p="0" yaw="0" mat="glass_tint"/>

  <!-- One visible chair on the right -->
  <xacro:dining_chair name="chair_right" parent="world" x="3.15" y="0.60" z="0.52" yaw="${-pi/2}"/>

</robot>